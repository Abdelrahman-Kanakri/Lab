# Lab configuration - edit these values once, everything else reads from here
# Source this file in your shell: source ~/lab/config.env

# Controller's IP on the lab network (your Nobara box)
# Get it with: ip -4 addr show | grep -oP '(?<=inet\s)192\.168\.\d+\.\d+'
export CONTROLLER_IP="10.3.5.96"

# MeshCentral admin username (the one you'll create on first login)
export MESH_ADMIN="admin"

# Lab IP range
export LAB_RANGE_START="10.3.5.1"
export LAB_RANGE_END="10.3.5.254"

# Paths
export LAB_DIR="$HOME/lab"
export LAB_FILES="$LAB_DIR/files"
export LAB_PLAYBOOKS="$LAB_DIR/playbooks"
export MESH_DIR="$LAB_DIR/meshcentral"
