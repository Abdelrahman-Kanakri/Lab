# =====================================================================
# Lab configuration — single source of truth for the controller box.
#
# Source this file in your shell:   source ~/lab/config.env
# Every shell script in ~/lab/ sources it automatically.
# =====================================================================

# ---- Network ----------------------------------------------------------
# Controller's IP on the lab subnet (your Nobara box).
# IMPORTANT: If this box gets a new DHCP address, update this variable.
# Get it with: ip -4 addr show | grep -oP '(?<=inet\s)\d+\.\d+\.\d+\.\d+'
export CONTROLLER_IP="10.3.5.96" # change to your address

# Lab subnet bounds. Scripts derive the /24 from LAB_RANGE_START.
# To move to a new subnet, change BOTH lines (e.g. 192.168.1.1 / 192.168.1.254).
export LAB_RANGE_START="10.3.5.1"
export LAB_RANGE_END="10.3.5.254"

# ---- Lab device credentials ------------------------------------------
# Local admin created on every Windows device by 01_Enroll-LabDevice.ps1.
# Used by Ansible (via hosts.ini) AND by all helper scripts.
# To rotate: see docs/06_CONTROLLER_CONFIG.md → "Rotate lab admin password"
export LAB_ADMIN_USER="labadmin"
export LAB_ADMIN_PASS="2026"

# ---- MeshCentral ------------------------------------------------------
# Username you'll create when first claiming the admin in the web UI.
# Informational — used in install messages and docs.
export MESH_ADMIN="admin"

# ---- Paths ------------------------------------------------------------
export LAB_DIR="$HOME/lab"
export LAB_FILES="$LAB_DIR/files"
export LAB_PLAYBOOKS="$LAB_DIR/playbooks"
export MESH_DIR="$LAB_DIR/meshcentral"

# ---- Tooling PATH ----------------------------------------------------
# ansible is installed via pip --user, so ~/.local/bin must be on PATH.
export PATH="$HOME/.local/bin:$PATH"
