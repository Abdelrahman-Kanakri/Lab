# =====================================================================
# Lab repo .gitignore
# Runtime / per-controller / per-deployment data — never commit.
# Anyone cloning regenerates these locally by running the scripts.
# =====================================================================

# MeshCentral install + per-server identity (certs, DB, signed agents)
meshcentral/

# Server-keyed agent + log staged for device pushes
files/MeshService64.exe
files/MeshService64.log

# Per-controller config (use config.env.example as the template)
config.env

# Auto-managed Ansible inventory (regenerated by 02_add_devices.sh)
hosts.ini

# Collected MAC list (regenerated by collect_macs.py)
macs.txt

# Editor / OS / Python cruft
__pycache__/
*.pyc
*.kate-swp
*.swp
.DS_Store

# Script run artifacts
/tmp/lab_*.txt
lab_*.txt

# Backups
backups/
