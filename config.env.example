# =====================================================================
# Lab configuration TEMPLATE.
#
# On a fresh box:
#     cp config.env.example config.env
#     # edit the values below to match your environment
#     source config.env
#
# Every shell script in ~/lab/ sources config.env automatically.
# config.env itself is gitignored — keep secrets there, not here.
# =====================================================================

# ---- Network ----------------------------------------------------------
# Controller's IP on the lab subnet (your Linux box).
# IMPORTANT: If this box gets a new DHCP address, update this variable.
# Get it with: ip -4 addr show | grep -oP '(?<=inet\s)\d+\.\d+\.\d+\.\d+'
export CONTROLLER_IP="<set-to-your-controller-ip>"

# Lab subnet bounds. Scripts derive the /24 from LAB_RANGE_START.
# To use a different subnet, change BOTH lines (e.g. 192.168.1.1 / 192.168.1.254).
export LAB_RANGE_START="<set-to-first-ip>"
export LAB_RANGE_END="<set-to-last-ip>"

# ---- Lab device credentials ------------------------------------------
# Local admin created on every Windows device by 01_Enroll-LabDevice.ps1.
# Used by Ansible (via hosts.ini) AND by all helper scripts.
# These MUST match the $user / $pass values inside
# windows-scripts/01_Enroll-LabDevice.ps1 — change them in both places.
# To rotate: see docs/06_CONTROLLER_CONFIG.md → "Rotate lab admin password"
export LAB_ADMIN_USER="INU"
export LAB_ADMIN_PASS="<choose-a-strong-password>"

# ---- MeshCentral ------------------------------------------------------
# Username you'll create when first claiming the admin in the web UI.
# Informational — used in install messages and docs.
export MESH_ADMIN="admin"

# ---- Paths ------------------------------------------------------------
export LAB_DIR="$HOME/lab"
export LAB_FILES="$LAB_DIR/files"
export LAB_PLAYBOOKS="$LAB_DIR/playbooks"
export MESH_DIR="$LAB_DIR/meshcentral"

# ---- Tooling PATH ----------------------------------------------------
# ansible is installed via pip --user, so ~/.local/bin must be on PATH.
export PATH="$HOME/.local/bin:$PATH"
